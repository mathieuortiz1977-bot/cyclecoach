# ─── Database ─────────────────────────────────────────────────────────
# SQLite (dev)
DATABASE_URL="file:./dev.db"
# PostgreSQL (production — Vercel Postgres / Neon / Supabase)
# DATABASE_URL="postgresql://user:pass@host:5432/cyclecoach?sslmode=require"

# ─── Auth (NextAuth.js) ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Strava API ──────────────────────────────────────────────────────
# https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=cyclecoach_verify

# ─── TrainingPeaks API ───────────────────────────────────────────────
# https://developers.trainingpeaks.com/
TP_CLIENT_ID=
TP_CLIENT_SECRET=

# ─── AI Coach (Anthropic Claude) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
