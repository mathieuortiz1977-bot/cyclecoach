# CycleCoach Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ═══════════════════════════════════════════════════════════════════════════
# AUTHENTICATION & SESSION
# ═══════════════════════════════════════════════════════════════════════════

# NextAuth Configuration
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════

# PostgreSQL / Neon
DATABASE_URL=postgresql://user:password@host/database
DATABASE_POSTGRES_URL=postgresql://user:password@host/database
DATABASE_POSTGRES_PRISMA_URL=postgresql://user:password@host/database
DATABASE_POSTGRES_URL_NO_SSL=postgresql://user:password@host/database
DATABASE_POSTGRES_URL_NON_POOLING=postgresql://user:password@host/database
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database

# Database Connection Details
DATABASE_POSTGRES_HOST=your-host
DATABASE_POSTGRES_USER=your-user
DATABASE_POSTGRES_PASSWORD=your-password
DATABASE_POSTGRES_DATABASE=your-database
DATABASE_PGHOST=your-host
DATABASE_PGHOST_UNPOOLED=your-host
DATABASE_PGUSER=your-user
DATABASE_PGPASSWORD=your-password
DATABASE_PGDATABASE=your-database

# Neon Integration
DATABASE_NEON_PROJECT_ID=your-neon-project-id
DATABASE_NEON_AUTH_BASE_URL=https://authn.neon.tech
DATABASE_VITE_NEON_AUTH_URL=https://authn.neon.tech

# ═══════════════════════════════════════════════════════════════════════════
# AI PROVIDERS
# ═══════════════════════════════════════════════════════════════════════════

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI GPT
OPENAI_API_KEY=sk-your-openai-key-here

# Primary AI Provider (anthropic or openai)
PRIMARY_AI_PROVIDER=anthropic

# ═══════════════════════════════════════════════════════════════════════════
# STRAVA INTEGRATION
# ═══════════════════════════════════════════════════════════════════════════

STRAVA_CLIENT_ID=208718
STRAVA_CLIENT_SECRET=your-strava-secret-here

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_BASE_URL=https://your-domain.com
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════════════════
# DEVELOPMENT (optional for local development)
# ═══════════════════════════════════════════════════════════════════════════

# Set to 'development' for local development
# NODE_ENV=development

# Enable NextAuth debugging
# NEXTAUTH_DEBUG=true
