generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth.js) ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // for credentials auth
  accounts      Account[]
  sessions      AuthSession[]
  rider         Rider?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Rider Profile ───────────────────────────────────────────────────

model Rider {
  id         String   @id @default(cuid())
  userId     String?  @unique
  user       User?    @relation(fields: [userId], references: [id])
  name       String
  ftp        Int      @default(200)
  weight     Float    @default(75)
  experience String   @default("INTERMEDIATE") // BEGINNER, INTERMEDIATE, ADVANCED
  coachTone  String   @default("MIXED")        // DARK_HUMOR, MOTIVATIONAL, TECHNICAL, MIXED
  maxHr      Int?     // max heart rate
  restingHr  Int?     // resting heart rate
  lthr       Int?     // lactate threshold heart rate
  trainingDays String @default("MON,TUE,THU,FRI,SAT") // comma-separated training days
  outdoorDay   String @default("SAT")          // which day is the outdoor ride
  programStartDate DateTime? // when the user started their CycleCoach program
  sundayDuration Int @default(90)              // average Sunday ride duration in minutes
  createdAt  DateTime @default(now())
  plans      Plan[]
  stravaConnection       StravaConnection?
  stravaActivities       StravaActivity[]
  // trainingPeaksConnection removed — using Zwift via .zwo files instead
  fitnessMetrics         FitnessMetric[]
  heartRateProfile       HeartRateProfile?
  completedWorkouts      CompletedWorkout[]
  workoutCancellations   WorkoutCancellation[]
  workoutModifications   WorkoutModification[]
  vacations              Vacation[]
}

model Plan {
  id              String   @id @default(cuid())
  riderId         String
  rider           Rider    @relation(fields: [riderId], references: [id])
  startDate       DateTime @default(now())
  currentBlockNum Int      @default(1)
  blocks          Block[]
}

model Block {
  id          String @id @default(cuid())
  planId      String
  plan        Plan   @relation(fields: [planId], references: [id])
  blockNumber Int
  type        String // BASE, THRESHOLD, VO2MAX, RACE_SIM
  weeks       Week[]
}

model Week {
  id         String    @id @default(cuid())
  blockId    String
  block      Block     @relation(fields: [blockId], references: [id])
  weekNumber Int
  weekType   String    // BUILD, BUILD_PLUS, OVERREACH, RECOVERY
  sessions   TrainingSession[]
}

model TrainingSession {
  id          String     @id @default(cuid())
  weekId      String
  week        Week       @relation(fields: [weekId], references: [id])
  dayOfWeek   String     // MON, TUE, THU, FRI, SAT
  sessionType String     // INDOOR, OUTDOOR
  duration    Int        // minutes
  title       String
  description String
  intervals   Interval[]
  routeId     String?
  route       Route?     @relation(fields: [routeId], references: [id])

  @@map("TrainingSession")
}

model Interval {
  id           String  @id @default(cuid())
  sessionId    String
  session      TrainingSession @relation(fields: [sessionId], references: [id])
  orderNum     Int
  name         String
  durationSecs Int
  powerLow     Float   // % of FTP
  powerHigh    Float   // % of FTP
  cadenceLow   Int?
  cadenceHigh  Int?
  rpe          Int?
  zone         String
  purpose      String
  coachNote    String
}

model Route {
  id          String    @id @default(cuid())
  name        String
  distance    Float     // km
  elevation   Float     // meters
  description String
  region      String    @default("Medellin")
  sessions    TrainingSession[]
}

// ─── Strava Integration ──────────────────────────────────────────────

model StravaConnection {
  id            String   @id @default(cuid())
  riderId       String   @unique
  rider         Rider    @relation(fields: [riderId], references: [id])
  athleteId     Int      @unique
  accessToken   String
  refreshToken  String
  expiresAt     Int      // unix timestamp
  scope         String   @default("read,activity:read_all")
  athleteName   String?
  athletePhoto  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StravaActivity {
  id              String   @id @default(cuid())
  stravaId        BigInt   @unique
  riderId         String
  rider           Rider    @relation(fields: [riderId], references: [id])
  name            String
  type            String   // Ride, VirtualRide, etc.
  startDate       DateTime
  movingTime      Int      // seconds
  elapsedTime     Int      // seconds
  distance        Float    // meters
  totalElevation  Float    // meters
  averageWatts    Float?
  maxWatts        Float?
  weightedAvgWatts Float?  // normalized power
  averageHeartrate Float?
  maxHeartrate    Float?
  averageCadence  Float?
  kilojoules      Float?
  sufferScore     Int?
  calories        Float?
  averageSpeed    Float?   // m/s
  maxSpeed        Float?   // m/s
  hasHeartrate    Boolean  @default(false)
  hasPower        Boolean  @default(false)
  mapPolyline     String?  // encoded polyline
  tss             Float?   // calculated Training Stress Score
  intensityFactor Float?   // calculated IF
  createdAt       DateTime @default(now())
}

// ─── TrainingPeaks removed — Zwift integration via .zwo files ────────

model FitnessMetric {
  id        String   @id @default(cuid())
  riderId   String
  rider     Rider    @relation(fields: [riderId], references: [id])
  date      DateTime
  ctl       Float    // Chronic Training Load (fitness)
  atl       Float    // Acute Training Load (fatigue)
  tsb       Float    // Training Stress Balance (form)
  tss       Float?   // daily TSS
  source    String   @default("calculated") // calculated, trainingpeaks
  createdAt DateTime @default(now())

  @@unique([riderId, date])
}

// ─── Completed Workouts ──────────────────────────────────────────────

model CompletedWorkout {
  id              String   @id @default(cuid())
  riderId         String
  rider           Rider    @relation(fields: [riderId], references: [id])
  sessionTitle    String
  dayOfWeek       String
  sessionType     String   // INDOOR, OUTDOOR
  plannedDuration Int      // minutes
  actualDuration  Int?     // minutes
  avgPower        Int?
  normalizedPower Int?
  avgHr           Int?
  maxHr           Int?
  rpe             Int?     // 1-10
  compliance      Int?     // 0-100
  feelings        String[] // array of feeling tags
  notes           String?
  completed       Boolean  @default(true)
  blockIdx        Int?
  weekIdx         Int?
  sessionIdx      Int?
  stravaActivityId String? // link to StravaActivity if auto-matched
  isProgramSession Boolean  @default(false) // true if this was a scheduled CycleCoach session
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
}

// ─── HR Zones ────────────────────────────────────────────────────────

model HeartRateProfile {
  id           String @id @default(cuid())
  riderId      String @unique
  rider        Rider  @relation(fields: [riderId], references: [id])
  maxHr        Int
  restingHr    Int    @default(60)
  lthr         Int?   // Lactate Threshold Heart Rate
  method       String @default("PERCENTAGE") // PERCENTAGE, KARVONEN
}

// ─── Workout Cancellations ──────────────────────────────────────────

model WorkoutCancellation {
  id          String   @id @default(cuid())
  workoutId   String   // identifier for the cancelled workout (could be planned session id)
  riderId     String
  rider       Rider    @relation(fields: [riderId], references: [id])
  reason      String   // reason for cancellation
  cancelledAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([workoutId, riderId]) // prevent duplicate cancellations
}

// ─── Workout Modifications ──────────────────────────────────────────

model WorkoutModification {
  id                   String   @id @default(cuid())
  workoutId            String   // identifier for the modified workout
  riderId              String
  rider                Rider    @relation(fields: [riderId], references: [id])
  originalTitle        String
  modifiedTitle        String
  originalDuration     Int      // minutes
  modifiedDuration     Int      // minutes
  originalTargetPower  Int      // percentage of FTP
  modifiedTargetPower  Int      // percentage of FTP
  sessionType          String
  modifiedAt           DateTime @default(now())
  createdAt            DateTime @default(now())

  @@unique([workoutId, riderId]) // prevent duplicate modifications
}

// ─── Vacations & Extended Breaks ─────────────────────────────────────

model Vacation {
  id          String   @id @default(cuid())
  riderId     String
  rider       Rider    @relation(fields: [riderId], references: [id])
  startDate   DateTime
  endDate     DateTime
  type        String   // complete_break, light_activity, cross_training
  description String?
  location    String?
  reason      String   @default("Planned vacation")
  
  // AI Analysis Results
  expectedFitnessLoss    String?  // e.g., "5-15%"
  detrainingLevel        String?  // Low, Moderate, High
  recoveryTime           String?  // e.g., "2-3 weeks"
  programExtensionWeeks  Int?     // weeks to extend program
  preVacationPlan        String?  // JSON string of pre-vacation adjustments
  postVacationPlan       String?  // JSON string of post-vacation return protocol
  
  // Status tracking
  isActive    Boolean  @default(false) // currently on vacation
  isApplied   Boolean  @default(false) // program adjustments have been applied
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([riderId, startDate, endDate]) // prevent duplicate vacations for same dates
}
