generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth (NextAuth.js) ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // for credentials auth
  accounts      Account[]
  sessions      AuthSession[]
  rider         Rider?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Rider Profile ───────────────────────────────────────────────────

model Rider {
  id         String   @id @default(cuid())
  userId     String?  @unique
  user       User?    @relation(fields: [userId], references: [id])
  name       String
  ftp        Int      @default(200)
  weight     Float    @default(75)
  experience String   @default("INTERMEDIATE") // BEGINNER, INTERMEDIATE, ADVANCED
  coachTone  String   @default("MIXED")        // DARK_HUMOR, MOTIVATIONAL, TECHNICAL, MIXED
  maxHr      Int?     // max heart rate
  restingHr  Int?     // resting heart rate
  lthr       Int?     // lactate threshold heart rate
  createdAt  DateTime @default(now())
  plans      Plan[]
  stravaConnection       StravaConnection?
  stravaActivities       StravaActivity[]
  trainingPeaksConnection TrainingPeaksConnection?
  fitnessMetrics         FitnessMetric[]
  heartRateProfile       HeartRateProfile?
}

model Plan {
  id              String   @id @default(cuid())
  riderId         String
  rider           Rider    @relation(fields: [riderId], references: [id])
  startDate       DateTime @default(now())
  currentBlockNum Int      @default(1)
  blocks          Block[]
}

model Block {
  id          String @id @default(cuid())
  planId      String
  plan        Plan   @relation(fields: [planId], references: [id])
  blockNumber Int
  type        String // BASE, THRESHOLD, VO2MAX, RACE_SIM
  weeks       Week[]
}

model Week {
  id         String    @id @default(cuid())
  blockId    String
  block      Block     @relation(fields: [blockId], references: [id])
  weekNumber Int
  weekType   String    // BUILD, BUILD_PLUS, OVERREACH, RECOVERY
  sessions   TrainingSession[]
}

model TrainingSession {
  id          String     @id @default(cuid())
  weekId      String
  week        Week       @relation(fields: [weekId], references: [id])
  dayOfWeek   String     // MON, TUE, THU, FRI, SAT
  sessionType String     // INDOOR, OUTDOOR
  duration    Int        // minutes
  title       String
  description String
  intervals   Interval[]
  routeId     String?
  route       Route?     @relation(fields: [routeId], references: [id])

  @@map("TrainingSession")
}

model Interval {
  id           String  @id @default(cuid())
  sessionId    String
  session      TrainingSession @relation(fields: [sessionId], references: [id])
  orderNum     Int
  name         String
  durationSecs Int
  powerLow     Float   // % of FTP
  powerHigh    Float   // % of FTP
  cadenceLow   Int?
  cadenceHigh  Int?
  rpe          Int?
  zone         String
  purpose      String
  coachNote    String
}

model Route {
  id          String    @id @default(cuid())
  name        String
  distance    Float     // km
  elevation   Float     // meters
  description String
  region      String    @default("Medellin")
  sessions    TrainingSession[]
}

// ─── Strava Integration ──────────────────────────────────────────────

model StravaConnection {
  id            String   @id @default(cuid())
  riderId       String   @unique
  rider         Rider    @relation(fields: [riderId], references: [id])
  athleteId     Int      @unique
  accessToken   String
  refreshToken  String
  expiresAt     Int      // unix timestamp
  scope         String   @default("read,activity:read_all")
  athleteName   String?
  athletePhoto  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StravaActivity {
  id              String   @id @default(cuid())
  stravaId        BigInt   @unique
  riderId         String
  rider           Rider    @relation(fields: [riderId], references: [id])
  name            String
  type            String   // Ride, VirtualRide, etc.
  startDate       DateTime
  movingTime      Int      // seconds
  elapsedTime     Int      // seconds
  distance        Float    // meters
  totalElevation  Float    // meters
  averageWatts    Float?
  maxWatts        Float?
  weightedAvgWatts Float?  // normalized power
  averageHeartrate Float?
  maxHeartrate    Float?
  averageCadence  Float?
  kilojoules      Float?
  sufferScore     Int?
  calories        Float?
  averageSpeed    Float?   // m/s
  maxSpeed        Float?   // m/s
  hasHeartrate    Boolean  @default(false)
  hasPower        Boolean  @default(false)
  mapPolyline     String?  // encoded polyline
  tss             Float?   // calculated Training Stress Score
  intensityFactor Float?   // calculated IF
  createdAt       DateTime @default(now())
}

// ─── TrainingPeaks Integration ───────────────────────────────────────

model TrainingPeaksConnection {
  id            String   @id @default(cuid())
  riderId       String   @unique
  rider         Rider    @relation(fields: [riderId], references: [id])
  accessToken   String
  refreshToken  String
  expiresAt     Int
  athleteId     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FitnessMetric {
  id        String   @id @default(cuid())
  riderId   String
  rider     Rider    @relation(fields: [riderId], references: [id])
  date      DateTime
  ctl       Float    // Chronic Training Load (fitness)
  atl       Float    // Acute Training Load (fatigue)
  tsb       Float    // Training Stress Balance (form)
  tss       Float?   // daily TSS
  source    String   @default("calculated") // calculated, trainingpeaks
  createdAt DateTime @default(now())

  @@unique([riderId, date])
}

// ─── HR Zones ────────────────────────────────────────────────────────

model HeartRateProfile {
  id           String @id @default(cuid())
  riderId      String @unique
  rider        Rider  @relation(fields: [riderId], references: [id])
  maxHr        Int
  restingHr    Int    @default(60)
  lthr         Int?   // Lactate Threshold Heart Rate
  method       String @default("PERCENTAGE") // PERCENTAGE, KARVONEN
}
